# 数据库连接（必填）
# 本地开发：postgresql://postgres@localhost:5432/student_community
# Docker 部署：下面这行留空，docker-compose 会自动拼接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/student_community"

# Docker 部署时 PostgreSQL 密码（生产环境务必修改）
POSTGRES_PASSWORD="postgres"

# NextAuth 密钥（必填，生产环境请更换为随机字符串）
# 生成方式: openssl rand -base64 32
AUTH_SECRET="change-this-to-a-random-secret-in-production"
AUTH_URL="http://localhost:3000"

# LLM 内容审核（选填，不填则跳过自动审核）
# 支持的提供商: "openai" | "anthropic" | "deepseek"
LLM_MODERATION_PROVIDER=""   # 推荐填 "deepseek"（价格最低）
LLM_MODERATION_API_KEY=""
